{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Preprocessing",
            "type": "debugpy",
            "request": "launch",
            "module": "imitation_learning.data_preprocessing",
            "args": [
                "--config",
                "src/imitation_learning/config.yaml",
                "--single-file",
                "data/games/3_games/4049.csv"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": false
        },
        {
            "name": "Debug play_with_model",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/play_with_model.py",
            "args": [
                "--model",
                "data/models/202511241159_config_tuning/best_model.pth",
                "--games",
                "1",
                "--display"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "justMyCode": false
        }
    ]
}